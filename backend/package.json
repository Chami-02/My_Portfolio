{
  "name": "portfolio-backend",
  "version": "1.0.0",
  "description": "Portfolio REST API — Express + MongoDB",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev":           "nodemon src/server.js",
    "start":         "node src/server.js",
    "seed":          "node src/seed.js",
    "test":          "node scripts/run-jest.js --runInBand --detectOpenHandles --forceExit",
    "test:coverage": "node scripts/run-jest.js --coverage --runInBand --detectOpenHandles --forceExit",
    "test:watch":    "node scripts/run-jest.js --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch":       ["**/__tests__/**/*.test.js"],
    "coverageThreshold": {
      "global": {
        "statements": 70,
        "branches":   60,
        "functions":  70,
        "lines":      70
      }
    },
    "coveragePathIgnorePatterns": ["/node_modules/", "src/seed.js"]
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.7.0",
    "morgan": "^1.11.0",
    "multer": "^2.2.0",
    "slugify": "^1.6.9"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
